<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F7FB">

    <!-- Top Bar -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/left_arrow_small"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Comments"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="#000000"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageButton
        android:id="@+id/btnNotifications"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/notification_popular"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toTopOf="@id/tvTitle"
        app:layout_constraintBottom_toBottomOf="@id/tvTitle"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Tab Bar -->
    <HorizontalScrollView
        android:id="@+id/tabScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingEnd="4dp">

            <Button
                android:id="@+id/detailBtn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:text="Details"
                android:textSize="12sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:cornerRadius="18dp"/>

            <Button
                android:id="@+id/waitListBtn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:text="Waitlist"
                android:textSize="12sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:cornerRadius="18dp"/>

            <Button
                android:id="@+id/entrantBtn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:text="Entrants"
                android:textSize="12sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:cornerRadius="18dp"/>

            <Button
                android:id="@+id/commentsBtn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:text="Messages"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#000000"
                app:cornerRadius="18dp"/>

            <Button
                android:id="@+id/editEventBtn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:text="Edit Event"
                android:textSize="12sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:cornerRadius="18dp"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Comments List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvComments"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tabScrollView"
        app:layout_constraintBottom_toTopOf="@id/dividerInput"/>

    <View
        android:id="@+id/dividerInput"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        app:layout_constraintBottom_toTopOf="@id/commentInputCard"/>

    <!-- Comment Input Bar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/commentInputCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <!-- User Avatar -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivCurrentUserAvatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:scaleType="centerCrop"/>

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etComment"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:hint="Add a comment..."
                android:background="@null"
                android:maxLines="4"
                android:textSize="14sp"
                android:inputType="textMultiLine|textCapSentences"/>

            <ImageButton
                android:id="@+id/btnSendComment"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/right_arrow_small"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#6200EE"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>