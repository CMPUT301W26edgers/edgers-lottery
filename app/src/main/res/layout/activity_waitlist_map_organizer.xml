<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#F9F7FB">

    <ImageButton
        android:id="@+id/btnBackEventDetails"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/left_arrow_small"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Event Map"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="#000000"
        app:layout_constraintTop_toTopOf="@id/btnBackEventDetails"
        app:layout_constraintBottom_toBottomOf="@id/btnBackEventDetails"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageButton
        android:id="@+id/btnNotifications"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/notification_popular"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toTopOf="@id/tvTitle"
        app:layout_constraintBottom_toBottomOf="@id/tvTitle"
        app:layout_constraintEnd_toEndOf="parent"/>

    <HorizontalScrollView
        android:id="@+id/tabScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="20dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/btnBackEventDetails"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/detailBtn"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Details"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:cornerRadius="20dp"/>

            <Button
                android:id="@+id/waitListBtn"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Waitlist"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:cornerRadius="20dp"/>

            <Button
                android:id="@+id/entrantBtn"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Entrants"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:cornerRadius="20dp"/>

            <Button
                android:id="@+id/mapBtn"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Map"
                android:textColor="#FFFFFF"
                android:backgroundTint="#000000"
                android:layout_marginEnd="8dp"
                app:cornerRadius="20dp"/>

            <Button
                android:id="@+id/editEventBtn"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Edit Event"
                android:layout_marginEnd="20dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:cornerRadius="20dp"/>

        </LinearLayout>
    </HorizontalScrollView>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/mapFragment"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintTop_toBottomOf="@id/tabScrollView"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:context=".views.organizer.OrganizerWaitlistMapActivity" />

</androidx.constraintlayout.widget.ConstraintLayout>