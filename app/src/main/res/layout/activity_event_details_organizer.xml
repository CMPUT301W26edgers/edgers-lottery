<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#F9F7FB">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <ImageButton
            android:id="@+id/btnBackEventDetails"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/left_arrow_small"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Event Details"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="#000000"
            app:layout_constraintTop_toTopOf="@id/btnBackEventDetails"
            app:layout_constraintBottom_toBottomOf="@id/btnBackEventDetails"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageButton
            android:id="@+id/btnNotifications"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/notification_popular"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintTop_toTopOf="@id/tvTitle"
            app:layout_constraintBottom_toBottomOf="@id/tvTitle"
            app:layout_constraintEnd_toEndOf="parent"/>

        <HorizontalScrollView
            android:id="@+id/tabScrollView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:scrollbars="horizontal"
            app:layout_constraintTop_toBottomOf="@id/btnBackEventDetails"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/detailBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Details"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#000000"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="20dp"/>

                <Button
                    android:id="@+id/waitListBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Waitlist"
                    android:layout_marginEnd="8dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:cornerRadius="20dp"/>

                <Button
                    android:id="@+id/entrantBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Entrants"
                    android:layout_marginEnd="8dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:cornerRadius="20dp"/>
                <Button
                    android:id="@+id/commentsBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Comments"
                    android:layout_marginEnd="8dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:cornerRadius="20dp"/>
                <Button
                    android:id="@+id/mapBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Map"
                    android:layout_marginEnd="8dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:cornerRadius="20dp"/>

                <Button
                    android:id="@+id/editEventBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Edit Event"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:cornerRadius="20dp"/>

            </LinearLayout>
        </HorizontalScrollView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardImages"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/tabScrollView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/vpEventImages"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/llDotIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/cardImages"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <LinearLayout
            android:id="@+id/llMetaRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/llDotIndicator"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvRegistrationCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registration ends in"
                android:textColor="#777777"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text=" • 1.2 miles"
                android:textColor="#777777"
                android:textSize="12sp"/>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvEventInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/llMetaRow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvEventTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Title"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/tvEntrantLimit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Entrant Limit: @limit"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Description: @description"
                    android:layout_marginTop="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp">

                    <Button
                        android:id="@+id/btnRunLottery"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Run Lottery"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#2ECC71"
                        android:elevation="6dp"
                        app:cornerRadius="24dp"/>

                    <Button
                        android:id="@+id/btnCancelEvent"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Cancel Event"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#E74C3C"
                        android:elevation="6dp"
                        app:cornerRadius="24dp"/>

                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp">

                    <Button
                        android:id="@+id/btnChosenEntrants"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="View Chosen"
                        android:textColor="#FFFFFF"
                        android:visibility="gone"
                        android:backgroundTint="#6076AC"
                        android:elevation="6dp"
                        app:cornerRadius="24dp"/>

                    <Button
                        android:id="@+id/btnCancelledEntrants"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="View No-Show"
                        android:visibility="gone"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#6076AC"
                        android:elevation="6dp"
                        app:cornerRadius="24dp"/>

                </LinearLayout>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/inviteContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:layout_constraintTop_toBottomOf="@id/cvEventInfo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Invite Users"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnInviteUser"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Invite by Email"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#3498DB"
                    app:cornerRadius="20dp"/>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!--
            QR code is shown inline when ispublic == true, hidden when private.
            Visibility is controlled programmatically in EventDetailsOrganizer.java.
            GONE by default so it takes no space until the Firestore load completes.
        -->
        <ImageView
            android:id="@+id/ivQrCode"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            android:contentDescription="Event QR Code"
            app:layout_constraintTop_toBottomOf="@id/cvEventInfo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>