<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F7FB">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Top Bar -->
        <ImageButton
            android:id="@+id/btnBackEventDetails"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/right_arrow_small"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Event Details"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="#000000"
            app:layout_constraintTop_toTopOf="@id/btnBackEventDetails"
            app:layout_constraintBottom_toBottomOf="@id/btnBackEventDetails"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageButton
            android:id="@+id/btnNotifications"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/notification_popular"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintTop_toTopOf="@id/tvTitle"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Tab Row -->
        <HorizontalScrollView
            android:id="@+id/tabScrollView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:scrollbars="none"
            app:layout_constraintTop_toBottomOf="@id/btnBackEventDetails">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnTabDetails"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Details"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#000000"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="20dp"/>

                <Button
                    android:id="@+id/btnTabWaitlist"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Waitlist"
                    android:layout_marginEnd="8dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:cornerRadius="20dp"/>

                <Button
                    android:id="@+id/btnTabEntrants"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Entrants"
                    android:layout_marginEnd="8dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:cornerRadius="20dp"/>

                <Button
                    android:id="@+id/btnTabEditEvent"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Edit Event"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:cornerRadius="20dp"/>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Image Carousel Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardImages"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/tabScrollView">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/vpEventImages"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Dot indicator -->
        <LinearLayout
            android:id="@+id/llDotIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="-20dp"
            app:layout_constraintTop_toBottomOf="@id/cardImages"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Location -->
        <TextView
            android:id="@+id/tvLocationName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Location name"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#000000"
            app:layout_constraintTop_toBottomOf="@id/llDotIndicator"/>

        <!-- Date -->
        <TextView
            android:id="@+id/tvDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Date"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#000000"
            app:layout_constraintTop_toBottomOf="@id/tvLocationName"/>

        <!-- Meta Row -->
        <LinearLayout
            android:id="@+id/llMetaRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/tvDate">

            <TextView
                android:id="@+id/tvRegistrationCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registration ends in"
                android:textSize="12sp"
                android:textColor="#777777"/>

            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" • 1.2 miles"
                android:textSize="12sp"
                android:textColor="#777777"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Info Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvEventInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/llMetaRow">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvEventTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Title"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/tvEntrantLimit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Entrant Limit: @limit"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Description: @description"
                    android:layout_marginTop="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp">

                    <Button
                        android:id="@+id/btnRunLottery"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Run Lottery"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#2ECC71"
                        android:elevation="6dp"
                        app:cornerRadius="24dp"/>

                    <Button
                        android:id="@+id/btnCancelEvent"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Cancel Event"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#E74C3C"
                        android:elevation="6dp"
                        app:cornerRadius="24dp"/>

                </LinearLayout>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- QR Button -->
        <Button
            android:id="@+id/btnQrCode"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="24dp"
            android:text="Generate / See QR Code"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            android:elevation="6dp"
            app:cornerRadius="25dp"
            app:layout_constraintTop_toBottomOf="@id/cvEventInfo"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>