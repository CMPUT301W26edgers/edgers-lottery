<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- Camera scanner (top half) -->
    <com.journeyapps.barcodescanner.DecoratedBarcodeView
        android:id="@+id/barcodeScanner"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/resultCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scan frame overlay -->
    <View
        android:id="@+id/scanFrame"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/qr_scan_border"
        app:layout_constraintTop_toTopOf="@id/barcodeScanner"
        app:layout_constraintBottom_toBottomOf="@id/barcodeScanner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvInstruction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Align QR code within the frame"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/resultCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Result card (bottom half) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/resultCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#1E1E1E"
        android:layout_margin="0dp"
        app:layout_constraintTop_toBottomOf="@id/barcodeScanner"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvResultLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scan a QR Code"
                    android:textColor="#00E676"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvRawResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Point your camera at a QR code to see its contents here."
                    android:textColor="#CCCCCC"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btnScanAgain"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Scan Again"
                    android:visibility="gone"
                    android:backgroundTint="#00E676"
                    android:textColor="#000000"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnBack"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cancel"
                    android:backgroundTint="#333333"
                    android:textColor="#FFFFFF" />

            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>